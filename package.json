{
  "name": "spending-tracker-budget-app",
  "version": "0.0.1",
  "description": "A budget tracker app for tracking financial",
  "productName": "SPENDING TRACKER BUDGET APP",
  "author": "djkenneth <dj.kenneth.pineda@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev -m pwa",
    "serve": "cd UAC && php artisan serve",
    "vite": "cd UAC && bun dev",
    "start": "concurrently --names \"API,VITE,APP\" --prefix-colors \"blue,cyan,green\" \"npm run serve\" \"npm run vite\" \"npm run dev\"",
    "build": "quasar build",
    "build:pwa": "quasar build -m pwa",
    "build:pwa:laravel": "quasar build -m pwa -d \"D:/P/SPENDING-TRACKING-BUDGET-APP-LARAVEL\"",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/vue-query": "^5.92.9",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "lucide-vue-next": "^0.562.0",
    "pinia": "^3.0.4",
    "quasar": "^2.18.6",
    "radix-vue": "^1.9.17",
    "register-service-worker": "^1.7.2",
    "reka-ui": "^2.8.2",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@quasar/app-vite": "^2.4.1",
    "@types/node": "^20.19.35",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "shadcn-vue": "^2.4.3",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.8.0",
    "vite-plugin-checker": "^0.9.3",
    "vue-tsc": "^2.2.12",
    "workbox-build": "^7.0.0",
    "workbox-cacheable-response": "^7.0.0",
    "workbox-core": "^7.0.0",
    "workbox-expiration": "^7.0.0",
    "workbox-precaching": "^7.0.0",
    "workbox-routing": "^7.0.0",
    "workbox-strategies": "^7.0.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
